{
  "name": "epheon",
  "private": true,
  "scripts": {
    "bench": "vitest bench --config benchmarks/vitest.config.ts",
    "build": "pnpm moon run :build",
    "conformance": "vitest run --config conformance/vitest.config.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "test": "vitest",
    "test:analytics": "vitest --reporter=junit --outputFile=test-report.junit.xml",
